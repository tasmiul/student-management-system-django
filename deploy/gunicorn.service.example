[Unit]
Description=SIMS Gunicorn Service
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/sims
Environment="DJANGO_DEBUG=False"
Environment="DJANGO_ALLOWED_HOSTS=example.com,www.example.com"
Environment="DJANGO_SECRET_KEY=change-me"
ExecStart=/opt/sims/.venv/bin/gunicorn sims.wsgi:application --bind 127.0.0.1:8000 --workers 3

[Install]
WantedBy=multi-user.target
